printf '%s\n' "#define HAVE_EVP_AES_128_CFB128 1" >>confdefs.h

fi

done

  for ac_func in wolfSSL_EVP_aes_128_ctr
do :
  ac_fn_c_check_func "$LINENO" "wolfSSL_EVP_aes_128_ctr" "ac_cv_func_wolfSSL_EVP_aes_128_ctr"
