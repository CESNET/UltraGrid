RESULT=`add_column "$RESULT" "Manual pages" $man $?`
RESULT=`add_column "$RESULT" "OpenCV${opencv_version_str?}" ${opencv?} $?`
RESULT=`add_column "$RESULT" "Profiling support" $profile $?`
