        VULKAN_LIBS=$pkg_cv_VULKAN_LIBS
        { printf '%s\n' "$as_me:${as_lineno-$LINENO}: result: yes" >&5
printf '%s\n' "yes" >&6; }
        found_vulkan=yes
fi
        fi
               for ac_header in vulkan/vulkan.h
do :
  ac_fn_c_check_header_compile "$LINENO" "vulkan/vulkan.h" "ac_cv_header_vulkan_vulkan_h" "$ac_includes_default"
if test "x$ac_cv_header_vulkan_vulkan_h" = xyes
then :
  printf '%s\n' "#define HAVE_VULKAN_VULKAN_H 1" >>confdefs.h

else case e in #(
  e) found_vulkan=no ;;
esac
fi

done

        if test $sdl = yes && test $sdl_version -ge 2 && test $found_vulkan = yes; then
                VULKAN_OBJ="src/video_display/vulkan/vulkan_sdl$sdl_version.o \
                        src/video_display/vulkan/vulkan_display.o \
                        src/video_display/vulkan/vulkan_context.o \
                        src/video_display/vulkan/vulkan_transfer_image.o \
