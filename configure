{ printf '%s\n' "$as_me:${as_lineno-$LINENO}: result: $ac_cv_lib_CFHDCodec_CFHD_OpenDecoder" >&5
printf '%s\n' "$ac_cv_lib_CFHDCodec_CFHD_OpenDecoder" >&6; }
