        { printf '%s\n' "$as_me:${as_lineno-$LINENO}: result: no" >&5
printf '%s\n' "no" >&6; }

if $PKG_CONFIG --atleast-pkgconfig-version 0.20; then
        _pkg_short_errors_supported=yes
else
        _pkg_short_errors_supported=no
